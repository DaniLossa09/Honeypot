# HoneypotX runtime configuration
# Copy this file to .env or run scripts/install.sh.

HPX_COWRIE_LOG=/home/cyferwall/honeypot/honeypots/logs/cowrie/cowrie.json
HPX_OPENCANARY_LOG=/home/cyferwall/honeypot/honeypots/logs/opencanary/opencanary.log
HPX_FTP_LOG=/home/cyferwall/honeypot/honeypots/logs/ftp/ftp.json

HPX_DB_PATH=/home/cyferwall/honeypot/data/honeypotx.db
HPX_GEO_CACHE_PATH=/home/cyferwall/honeypot/data/cache/geo_cache.json
HPX_OFFSETS_PATH=/home/cyferwall/honeypot/data/state/offsets.json
HPX_EVENTS_EXPORT_PATH=/home/cyferwall/honeypot/data/exports/events_export.json

HPX_DASHBOARD_AUTH_PATH=/home/cyferwall/honeypot/config/dashboard_auth.json
HPX_ATTACK_SETTINGS_PATH=/home/cyferwall/honeypot/config/attack_settings.json

# Dashboard usata in LAN -> API raggiungibile dai device remoti (0.0.0.0).
# Per restringere al solo Pi: 127.0.0.1. Endpoint dati protetti da auth.
HPX_API_HOST=0.0.0.0
HPX_API_PORT=8000
# '*' = wildcard (credenziali CORS disattivate). Altrimenti origini CSV esplicite,
# es. HPX_FRONTEND_ORIGIN=http://localhost:5500,http://127.0.0.1:5500
HPX_FRONTEND_ORIGIN=*
HPX_POLL_INTERVAL=3
HPX_GEO_API_BASE=http://ip-api.com/json
