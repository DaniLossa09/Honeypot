+def _unique_values(rows: Iterable[Dict[str, Any]], field: str, limit: int = 12) -> List[str]:
+    values = []
+    seen = set()
+    for row in rows:
+        value = str(row.get(field) or '').strip()
+        if not value or value in seen:
+            continue
+        seen.add(value)
+        values.append(value)
+        if len(values) >= limit:
+            break
+    return values
