function drawAttackLine(ev, isNew) {
  if (!map) return;
  const exp    = EXPLANATIONS[ev.id];
  const danger = exp ? exp.danger_level : 'Basso';
  const color  = danger === 'Alto' ? '#ff3355' : danger === 'Medio' ? '#ffaa00' : '#00ff88';

  const line = L.polyline(
    [[ev.lat, ev.lon], [TARGET_LAT, TARGET_LON]],
    { color, weight: isNew ? 2 : 1, opacity: isNew ? 0.9 : 0.35, dashArray: '6,8' }
  ).addTo(map);

  attackLines.push(line);

  // Animate dash offset
  let offset = 0;
  const anim = setInterval(() => {
    offset = (offset + 2) % 14;
    line.setStyle({ dashOffset: -offset });
  }, 60);

  // Fade out old lines after 12s (new ones after 8s)
  const timeout = isNew ? 8000 : 14000;
  setTimeout(() => {
    clearInterval(anim);
    let op = isNew ? 0.9 : 0.35;
    const fade = setInterval(() => {
      op -= 0.05;
      if (op <= 0) { clearInterval(fade); map.removeLayer(line); }
      else line.setStyle({ opacity: op });
    }, 100);
  }, timeout);
}

function drawAllLines() {
  EVENTS.forEach(ev => drawAttackLine(ev, false));
}

