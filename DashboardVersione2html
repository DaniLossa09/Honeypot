<!DOCTYPE html>
<html lang="it">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>HoneypotX — Cyber Threat Intelligence</title>
<link href="https://fonts.googleapis.com/css2?family=Share+Tech+Mono&family=Rajdhani:wght@400;600;700&family=Inter:wght@300;400;500&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"/>
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.min.js"></script>
<style>
  :root {
    --bg:       #080c10;
    --surface:  #0d1117;
    --border:   #1a2332;
    --accent:   #00ff88;
    --accent2:  #00aaff;
    --danger:   #ff3355;
    --warn:     #ffaa00;
    --safe:     #00ff88;
    --text:     #c9d1d9;
    --muted:    #4a5568;
    --font-mono: 'Share Tech Mono', monospace;
    --font-head: 'Rajdhani', sans-serif;
    --font-body: 'Inter', sans-serif;
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }

  body {
    background: var(--bg);
    color: var(--text);
    font-family: var(--font-body);
    min-height: 100vh;
    overflow-x: hidden;
  }

  body::before {
    content: '';
    position: fixed;
    inset: 0;
    background-image:
      linear-gradient(rgba(0,255,136,0.03) 1px, transparent 1px),
      linear-gradient(90deg, rgba(0,255,136,0.03) 1px, transparent 1px);
    background-size: 40px 40px;
    pointer-events: none;
    z-index: 0;
  }

  /* ── HEADER ── */
  header {
    position: relative;
    z-index: 10;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 14px 32px;
    border-bottom: 1px solid var(--border);
    background: rgba(13,17,23,0.97);
    backdrop-filter: blur(12px);
  }

  .logo { display: flex; align-items: center; gap: 12px; }

  .logo-icon {
    width: 36px; height: 36px;
    border: 2px solid var(--accent);
    border-radius: 8px;
    display: flex; align-items: center; justify-content: center;
    font-size: 18px;
    box-shadow: 0 0 12px rgba(0,255,136,0.3);
    animation: pulse-border 2s ease-in-out infinite;
  }

  @keyframes pulse-border {
    0%, 100% { box-shadow: 0 0 12px rgba(0,255,136,0.3); }
    50%       { box-shadow: 0 0 28px rgba(0,255,136,0.7); }
  }

  .logo-text {
    font-family: var(--font-head);
    font-size: 22px;
    font-weight: 700;
    letter-spacing: 2px;
    color: #fff;
  }
  .logo-text span { color: var(--accent); }

  .header-right { display: flex; align-items: center; gap: 16px; }

  .live-badge {
    display: flex; align-items: center; gap: 6px;
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--accent);
    letter-spacing: 1px;
  }

  .live-dot {
    width: 7px; height: 7px;
    background: var(--accent);
    border-radius: 50%;
    animation: blink 1.2s ease-in-out infinite;
  }

  @keyframes blink {
    0%, 100% { opacity: 1; }
    50%       { opacity: 0.2; }
  }

  .timestamp { font-family: var(--font-mono); font-size: 11px; color: var(--muted); }

  /* ── SIMULATE BUTTON ── */
  .sim-btn {
    display: flex; align-items: center; gap: 8px;
    background: linear-gradient(135deg, rgba(255,51,85,0.15), rgba(255,170,0,0.1));
    border: 1px solid rgba(255,51,85,0.4);
    color: var(--danger);
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 1px;
    padding: 7px 16px;
    border-radius: 8px;
    cursor: pointer;
    transition: all 0.2s;
    position: relative;
    overflow: hidden;
  }

  .sim-btn::before {
    content: '';
    position: absolute;
    inset: 0;
    background: rgba(255,51,85,0.1);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.3s;
  }

  .sim-btn:hover::before { transform: scaleX(1); }
  .sim-btn:hover { border-color: var(--danger); box-shadow: 0 0 16px rgba(255,51,85,0.3); }

  .sim-btn.firing {
    animation: btn-flash 0.4s ease;
    border-color: var(--danger);
    box-shadow: 0 0 24px rgba(255,51,85,0.5);
  }

  @keyframes btn-flash {
    0%   { background: rgba(255,51,85,0.4); }
    100% { background: rgba(255,51,85,0.1); }
  }

  /* ── ALERT BANNER ── */
  .alert-banner {
    position: fixed;
    top: 70px; right: 24px;
    z-index: 999;
    display: flex;
    flex-direction: column;
    gap: 8px;
    max-width: 340px;
  }

  .alert-toast {
    background: rgba(255,51,85,0.12);
    border: 1px solid rgba(255,51,85,0.4);
    border-left: 3px solid var(--danger);
    border-radius: 8px;
    padding: 12px 16px;
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--text);
    animation: toast-in 0.3s ease, toast-out 0.4s ease 4s forwards;
    backdrop-filter: blur(8px);
  }

  .alert-toast .alert-title { color: var(--danger); font-size: 10px; letter-spacing: 1px; margin-bottom: 4px; }

  @keyframes toast-in {
    from { opacity: 0; transform: translateX(30px); }
    to   { opacity: 1; transform: translateX(0); }
  }

  @keyframes toast-out {
    to { opacity: 0; transform: translateX(30px); }
  }

  /* ── LAYOUT ── */
  main {
    position: relative;
    z-index: 1;
    padding: 20px 32px;
    max-width: 1600px;
    margin: 0 auto;
  }

  /* ── STAT CARDS ── */
  .stats-row {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 14px;
    margin-bottom: 20px;
  }

  .stat-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 18px 22px;
    position: relative;
    overflow: hidden;
    transition: border-color 0.3s, transform 0.2s;
    cursor: default;
  }

  .stat-card::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 2px;
  }

  .stat-card.danger::before  { background: linear-gradient(90deg, var(--danger), transparent); }
  .stat-card.warn::before    { background: linear-gradient(90deg, var(--warn), transparent); }
  .stat-card.safe::before    { background: linear-gradient(90deg, var(--safe), transparent); }
  .stat-card.info::before    { background: linear-gradient(90deg, var(--accent2), transparent); }

  .stat-card:hover { border-color: var(--accent); transform: translateY(-2px); }

  .stat-card.flash-attack {
    animation: card-flash 0.6s ease;
  }

  @keyframes card-flash {
    0%   { border-color: var(--danger); box-shadow: 0 0 20px rgba(255,51,85,0.4); }
    100% { border-color: var(--border); box-shadow: none; }
  }

  .stat-label { font-family: var(--font-mono); font-size: 10px; color: var(--muted); letter-spacing: 2px; text-transform: uppercase; margin-bottom: 8px; }
  .stat-value { font-family: var(--font-head); font-size: 42px; font-weight: 700; line-height: 1; color: #fff; }
  .stat-value.danger { color: var(--danger); }
  .stat-value.warn   { color: var(--warn); }
  .stat-value.safe   { color: var(--safe); }
  .stat-value.info   { color: var(--accent2); }
  .stat-sub { font-size: 11px; color: var(--muted); margin-top: 4px; }

  /* ── MIDDLE ROW ── */
  .middle-row {
    display: grid;
    grid-template-columns: 1fr 340px;
    gap: 16px;
    margin-bottom: 16px;
  }

  .card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 12px;
    overflow: hidden;
  }

  .card-header {
    display: flex; align-items: center; justify-content: space-between;
    padding: 14px 20px;
    border-bottom: 1px solid var(--border);
  }

  .card-title {
    font-family: var(--font-head); font-size: 13px; font-weight: 600;
    letter-spacing: 2px; text-transform: uppercase; color: #fff;
    display: flex; align-items: center; gap: 8px;
  }

  .card-title .dot { width: 6px; height: 6px; background: var(--accent); border-radius: 50%; animation: blink 1.2s ease-in-out infinite; }

  /* ── MAP ── */
  #map { height: 380px; background: #0a0e14; }
  .leaflet-container { background: #0a0e14 !important; }

  /* ── ATTACK LINE CANVAS ── */
  #attack-canvas {
    position: absolute;
    top: 0; left: 0;
    pointer-events: none;
    z-index: 400;
  }

  /* ── CHART ── */
  .chart-wrap { padding: 20px; display: flex; flex-direction: column; gap: 16px; }
  #attackChart { max-height: 200px; }
  .legend { display: flex; flex-direction: column; gap: 8px; }
  .legend-item { display: flex; align-items: center; justify-content: space-between; font-size: 12px; }
  .legend-left { display: flex; align-items: center; gap: 8px; }
  .legend-dot { width: 8px; height: 8px; border-radius: 2px; flex-shrink: 0; }
  .legend-name { color: var(--text); }
  .legend-count { font-family: var(--font-mono); color: var(--accent); font-size: 11px; }

  /* ── AI INSIGHTS PANEL ── */
  .ai-insights-card {
    background: var(--surface);
    border: 1px solid rgba(0,255,136,0.2);
    border-radius: 12px;
    overflow: hidden;
    margin-bottom: 16px;
    position: relative;
  }

  .ai-insights-card::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 2px;
    background: linear-gradient(90deg, var(--accent), var(--accent2), var(--accent));
    background-size: 200% 100%;
    animation: gradient-slide 3s linear infinite;
  }

  @keyframes gradient-slide {
    0%   { background-position: 0% 0%; }
    100% { background-position: 200% 0%; }
  }

  .ai-insights-inner {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 0;
  }

  .ai-insight-col {
    padding: 20px 24px;
    border-right: 1px solid var(--border);
    position: relative;
  }

  .ai-insight-col:last-child { border-right: none; }

  .ai-col-label {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 2px;
    text-transform: uppercase;
    margin-bottom: 10px;
  }

  .ai-col-label.attack-label  { color: var(--danger); }
  .ai-col-label.risk-label    { color: var(--warn); }
  .ai-col-label.advice-label  { color: var(--accent2); }

  .ai-col-content { font-size: 13px; line-height: 1.6; color: var(--text); }

  .risk-badge {
    display: inline-flex; align-items: center; gap: 6px;
    padding: 6px 14px;
    border-radius: 20px;
    font-family: var(--font-mono);
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 1px;
    margin-bottom: 8px;
  }

  .risk-high   { background: rgba(255,51,85,0.15);  color: var(--danger); border: 1px solid rgba(255,51,85,0.4); }
  .risk-medium { background: rgba(255,170,0,0.15);  color: var(--warn);   border: 1px solid rgba(255,170,0,0.4); }
  .risk-low    { background: rgba(0,255,136,0.1);   color: var(--safe);   border: 1px solid rgba(0,255,136,0.3); }

  .ai-typing::after {
    content: '▋';
    animation: cursor-blink 0.8s step-end infinite;
    color: var(--accent);
  }

  @keyframes cursor-blink {
    0%, 100% { opacity: 1; }
    50%       { opacity: 0; }
  }

  /* ── BOTTOM ROW ── */
  .bottom-row {
    display: grid;
    grid-template-columns: 1fr 380px;
    gap: 16px;
    margin-bottom: 20px;
  }

  /* ── TABELLA ── */
  .events-controls { display: flex; align-items: center; gap: 10px; }

  .filter-btn {
    font-family: var(--font-mono);
    font-size: 10px;
    padding: 4px 12px;
    border-radius: 20px;
    border: 1px solid var(--border);
    background: transparent;
    color: var(--muted);
    cursor: pointer;
    letter-spacing: 1px;
    transition: all 0.2s;
  }

  .filter-btn.active, .filter-btn:hover {
    border-color: var(--accent);
    color: var(--accent);
    background: rgba(0,255,136,0.05);
  }

  .events-table-wrap { overflow-x: auto; max-height: 320px; overflow-y: auto; }

  table { width: 100%; border-collapse: collapse; font-size: 13px; }

  thead th {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 2px;
    color: var(--muted);
    text-transform: uppercase;
    padding: 10px 16px;
    text-align: left;
    border-bottom: 1px solid var(--border);
    position: sticky;
    top: 0;
    background: var(--surface);
    z-index: 1;
  }

  tbody tr {
    border-bottom: 1px solid rgba(26,35,50,0.5);
    cursor: pointer;
    transition: background 0.15s;
  }

  tbody tr:hover { background: rgba(0,255,136,0.04); }

  tbody tr.new-row {
    animation: row-flash 1.5s ease forwards;
  }

  @keyframes row-flash {
    0%   { background: rgba(255,51,85,0.15); }
    100% { background: transparent; }
  }

  tbody td { padding: 10px 16px; vertical-align: middle; }

  .badge {
    display: inline-flex; align-items: center;
    padding: 3px 10px;
    border-radius: 20px;
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 1px;
    font-weight: 600;
  }

  .badge-danger { background: rgba(255,51,85,0.15);  color: var(--danger); border: 1px solid rgba(255,51,85,0.3); }
  .badge-warn   { background: rgba(255,170,0,0.15);  color: var(--warn);   border: 1px solid rgba(255,170,0,0.3); }
  .badge-safe   { background: rgba(0,255,136,0.1);   color: var(--safe);   border: 1px solid rgba(0,255,136,0.3); }

  .attack-type { font-weight: 500; color: #fff; }
  .ip-text { font-family: var(--font-mono); font-size: 12px; color: var(--accent2); }
  .country-text { color: var(--muted); font-size: 12px; }
  .service-text { font-family: var(--font-mono); font-size: 11px; color: var(--muted); background: var(--border); padding: 2px 8px; border-radius: 4px; }

  /* ── LIVE FEED ── */
  .live-feed-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 12px;
    overflow: hidden;
  }

  .feed-list {
    padding: 8px 0;
    max-height: 360px;
    overflow-y: auto;
  }

  .feed-item {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    padding: 10px 16px;
    border-bottom: 1px solid rgba(26,35,50,0.4);
    cursor: pointer;
    transition: background 0.15s;
    animation: feed-slide 0.4s ease;
  }

  .feed-item:hover { background: rgba(0,255,136,0.03); }

  @keyframes feed-slide {
    from { opacity: 0; transform: translateX(-10px); }
    to   { opacity: 1; transform: translateX(0); }
  }

  .feed-time {
    font-family: var(--font-mono);
    font-size: 10px;
    color: var(--muted);
    white-space: nowrap;
    padding-top: 2px;
    flex-shrink: 0;
  }

  .feed-info { flex: 1; }
  .feed-attack { font-size: 12px; color: #fff; font-weight: 500; }
  .feed-detail { font-family: var(--font-mono); font-size: 10px; color: var(--muted); margin-top: 2px; }
  .feed-country { font-size: 11px; margin-top: 2px; color: var(--accent2); }

  .feed-dot {
    width: 8px; height: 8px;
    border-radius: 50%;
    flex-shrink: 0;
    margin-top: 4px;
  }

  /* ── MODAL ── */
  .modal-overlay {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(8,12,16,0.85);
    backdrop-filter: blur(8px);
    z-index: 1000;
    align-items: center;
    justify-content: center;
  }

  .modal-overlay.open { display: flex; }

  .modal {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 16px;
    width: 90%;
    max-width: 680px;
    max-height: 88vh;
    overflow-y: auto;
    position: relative;
    animation: modal-in 0.25s ease;
  }

  @keyframes modal-in {
    from { opacity: 0; transform: translateY(20px) scale(0.97); }
    to   { opacity: 1; transform: translateY(0) scale(1); }
  }

  .modal-top-bar {
    height: 3px;
    background: linear-gradient(90deg, var(--danger), var(--warn), var(--accent2));
  }

  .modal-header {
    padding: 20px 28px 16px;
    border-bottom: 1px solid var(--border);
    display: flex; align-items: flex-start; justify-content: space-between; gap: 16px;
  }

  .modal-attack-type { font-family: var(--font-head); font-size: 22px; font-weight: 700; color: #fff; letter-spacing: 1px; }
  .modal-source { font-family: var(--font-mono); font-size: 10px; color: var(--muted); margin-top: 4px; letter-spacing: 1px; }

  .modal-close {
    background: none; border: none; color: var(--muted); font-size: 20px;
    cursor: pointer; padding: 4px; line-height: 1; flex-shrink: 0; transition: color 0.2s;
  }

  .modal-close:hover { color: #fff; }
  .modal-body { padding: 24px 28px; }

  .modal-meta { display: flex; flex-wrap: wrap; gap: 10px; margin-bottom: 20px; }

  .meta-chip {
    display: flex; align-items: center; gap: 6px;
    font-family: var(--font-mono); font-size: 11px; color: var(--muted);
    background: rgba(255,255,255,0.04);
    padding: 6px 12px; border-radius: 8px; border: 1px solid var(--border);
  }

  .meta-chip span { color: var(--text); }

  .ai-section {
    background: rgba(0,255,136,0.04);
    border: 1px solid rgba(0,255,136,0.15);
    border-radius: 12px; padding: 20px; margin-bottom: 14px;
  }

  .ai-label {
    font-family: var(--font-mono); font-size: 10px; color: var(--accent);
    letter-spacing: 2px; margin-bottom: 10px; display: flex; align-items: center; gap: 6px;
  }

  .ai-text { font-size: 14px; line-height: 1.7; color: var(--text); }

  .advice-section {
    background: rgba(0,170,255,0.05);
    border: 1px solid rgba(0,170,255,0.15);
    border-radius: 12px; padding: 16px 20px;
  }

  .advice-label {
    font-family: var(--font-mono); font-size: 10px; color: var(--accent2);
    letter-spacing: 2px; margin-bottom: 8px;
  }

  .advice-text { font-size: 13px; line-height: 1.6; color: var(--text); }

  /* ── SCROLLBAR ── */
  ::-webkit-scrollbar { width: 5px; height: 5px; }
  ::-webkit-scrollbar-track { background: var(--bg); }
  ::-webkit-scrollbar-thumb { background: var(--border); border-radius: 3px; }

  /* ── RESPONSIVE ── */
  @media (max-width: 1100px) {
    .ai-insights-inner { grid-template-columns: 1fr 1fr; }
    .ai-insight-col:last-child { border-top: 1px solid var(--border); grid-column: 1/-1; }
  }

  @media (max-width: 900px) {
    .stats-row { grid-template-columns: repeat(2, 1fr); }
    .middle-row, .bottom-row { grid-template-columns: 1fr; }
    .ai-insights-inner { grid-template-columns: 1fr; }
    main { padding: 14px; }
    header { padding: 12px 16px; }
  }

  .empty { text-align: center; padding: 40px; color: var(--muted); font-family: var(--font-mono); font-size: 13px; }

  /* Map popup */
  .dark-popup .leaflet-popup-content-wrapper {
    background: #0d1117; border: 1px solid #1a2332; color: #c9d1d9; border-radius: 8px;
  }
  .dark-popup .leaflet-popup-tip { background: #0d1117; }

  /* Leaflet map container position fix */
  .map-container-wrap { position: relative; }
</style>
</head>
<body>

<div class="alert-banner" id="alertBanner"></div>

<!-- HEADER -->
<header>
  <div class="logo">
    <div class="logo-icon">🍯</div>
    <div class="logo-text">Honeypot<span>X</span></div>
  </div>
  <div class="header-right">
    <button class="sim-btn" id="simBtn" onclick="triggerSimulatedAttack()">
      ⚡ SIMULA ATTACCO
    </button>
    <div class="live-badge">
      <div class="live-dot"></div>
      MONITORING ACTIVE
    </div>
    <div class="timestamp" id="clock">--:--:--</div>
  </div>
</header>

<main>

  <!-- KPI CARDS -->
  <div class="stats-row">
    <div class="stat-card danger" id="card-total">
      <div class="stat-label">⚡ Attacchi Totali</div>
      <div class="stat-value danger" id="stat-total">0</div>
      <div class="stat-sub">eventi rilevati</div>
    </div>
    <div class="stat-card danger" id="card-high">
      <div class="stat-label">🔴 Pericolo Alto</div>
      <div class="stat-value danger" id="stat-high">0</div>
      <div class="stat-sub">richiedono attenzione</div>
    </div>
    <div class="stat-card warn">
      <div class="stat-label">🟡 Pericolo Medio</div>
      <div class="stat-value warn" id="stat-medium">0</div>
      <div class="stat-sub">da monitorare</div>
    </div>
    <div class="stat-card info">
      <div class="stat-label">🌍 Paesi Attaccanti</div>
      <div class="stat-value info" id="stat-countries">0</div>
      <div class="stat-sub">origini uniche</div>
    </div>
  </div>

  <!-- MAPPA + DONUT -->
  <div class="middle-row">
    <div class="card">
      <div class="card-header">
        <div class="card-title"><div class="dot"></div> MAPPA ATTACCHI GLOBALE</div>
