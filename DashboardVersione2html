  document.getElementById('ai-risk').innerHTML =
    `<span class="risk-badge risk-${color}">${icon} ${danger.toUpperCase()}</span>`;

  const shortExp = exp?.explanation_it?.split('.')[0] + '.' || '—';
  document.getElementById('ai-explanation').textContent = shortExp;

  document.getElementById('ai-advice').innerHTML =
    `<span style="font-size:13px;line-height:1.6;color:var(--text)">${exp?.advice || '—'}</span>`;

  // Flash the AI card
  const card = document.getElementById('aiInsightsCard');
  card.style.borderColor = 'rgba(0,255,136,0.5)';
  card.style.boxShadow   = '0 0 20px rgba(0,255,136,0.1)';
  setTimeout(() => {
    card.style.borderColor = '';
    card.style.boxShadow   = '';
  }, 1200);
}

// ── TABLE ──────────────────────────────────────────────────────────────────
function renderTable(events, highlightFirst) {
  const tbody = document.getElementById('eventsBody');
  if (!events.length) {
    tbody.innerHTML = '<tr><td colspan="6" class="empty">Nessun evento trovato</td></tr>';
    return;
  }

  tbody.innerHTML = events.map((ev, idx) => {
    const exp    = EXPLANATIONS[ev.id];
    const danger = exp ? exp.danger_level : '—';
    const ts     = new Date(ev.timestamp).toLocaleString('it-IT');
    const badgeClass = danger === 'Alto' ? 'badge-danger' : danger === 'Medio' ? 'badge-warn' : 'badge-safe';
    const dangerIcon = danger === 'Alto' ? '🔴' : danger === 'Medio' ? '🟡' : '🟢';
    const newClass   = (highlightFirst && idx === 0) ? ' class="new-row"' : '';

    return `<tr${newClass} onclick="openModal(${ev.id})">
      <td><span class="badge ${badgeClass}">${dangerIcon} ${danger}</span></td>
      <td class="attack-type">${ev.flag || '🌐'} ${ev.attack_type}</td>
      <td class="ip-text">${ev.ip}</td>
      <td class="country-text">${ev.city}, ${ev.country}</td>
      <td><span class="service-text">${ev.service.toUpperCase()}</span></td>
      <td class="country-text">${ts}</td>
    </tr>`;
  }).join('');
}

function filterEvents(level, btn) {
  currentFilter = level;
  document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
  btn.classList.add('active');
  const filtered = level === 'all' ? EVENTS : EVENTS.filter(ev => {
    const exp = EXPLANATIONS[ev.id];
    return exp && exp.danger_level === level;
  });
  renderTable(filtered);
}

// ── SIMULATE ATTACK ────────────────────────────────────────────────────────
function createNewEvent(base) {
  const now = new Date();
  const id  = nextId++;
  EXPLANATIONS[id] = EXPLANATIONS[base.id] ? { ...EXPLANATIONS[base.id] } : {
    danger_level: 'Alto',
    explanation_it: 'Nuovo attacco rilevato in tempo reale dal sistema HoneypotX.',
    advice: 'Monitorare attentamente e applicare le contromisure appropriate.'
  };
  return {
    ...base,
    id,
    timestamp: now.toISOString(),
  };
}

function processNewAttack(ev) {
  EVENTS.unshift(ev);

  // Update UI
  initStats();
  drawAttackLine(ev, true);
  addToFeed(ev, true);
  updateAIInsights(ev);

  // Flash cards
  flashCard('card-total');
  const exp = EXPLANATIONS[ev.id];
  if (exp?.danger_level === 'Alto') flashCard('card-high');

  // Show alert toast
  const danger = exp?.danger_level || '?';
  if (danger === 'Alto') {
    showAlert(`⚠️ ${ev.attack_type} da ${ev.flag||'🌐'} ${ev.country}`, `IP: ${ev.ip} · Servizio: ${ev.service.toUpperCase()}`);
  }

  // Re-render table
  if (currentFilter === 'all') renderTable(EVENTS, true);
  else filterEvents(currentFilter, document.querySelector('.filter-btn.active'));

  // Add marker
  const color = danger === 'Alto' ? '#ff3355' : danger === 'Medio' ? '#ffaa00' : '#00ff88';
  const size  = 12;
  const icon  = L.divIcon({
    html: `<div style="width:${size}px;height:${size}px;background:${color};border-radius:50%;border:2px solid rgba(255,255,255,0.4);box-shadow:0 0 ${size*2}px ${color};animation:blink 1s ease-in-out 3;"></div>`,
    className:'', iconSize:[size,size], iconAnchor:[size/2,size/2]
  });
  L.marker([ev.lat, ev.lon], { icon })
    .addTo(map)
    .on('click', () => openModal(ev.id));
}

function autoSimulateAttack() {
  const pool = [...BASE_EVENTS, ...EXTRA_ATTACKS];
  const base = pool[Math.floor(Math.random() * pool.length)];
  const ev   = createNewEvent(base);
  processNewAttack(ev);
}

function triggerSimulatedAttack() {
  const btn = document.getElementById('simBtn');
  btn.classList.add('firing');
  setTimeout(() => btn.classList.remove('firing'), 500);
  autoSimulateAttack();
}

// ── ALERT TOAST ────────────────────────────────────────────────────────────
function showAlert(title, body) {
  const banner = document.getElementById('alertBanner');
  const toast  = document.createElement('div');
  toast.className = 'alert-toast';
  toast.innerHTML = `<div class="alert-title">🚨 ATTACCO RILEVATO</div>${title}<br><span style="color:var(--muted);font-size:10px;">${body}</span>`;
  banner.appendChild(toast);
  setTimeout(() => toast.remove(), 5000);
}

// ── MODAL ──────────────────────────────────────────────────────────────────
function openModal(id) {
  const ev  = EVENTS.find(e => e.id === id);
  const exp = EXPLANATIONS[id];
  if (!ev) return;

  document.getElementById('modalTitle').textContent  = ev.attack_type;
  document.getElementById('modalSource').textContent = `SOURCE: ${ev.source?.toUpperCase() || 'HONEYPOTX'} · ID: #${ev.id}`;

  const danger     = exp ? exp.danger_level : '—';
  const badgeClass = danger === 'Alto' ? 'badge-danger' : danger === 'Medio' ? 'badge-warn' : 'badge-safe';
  const ts         = new Date(ev.timestamp).toLocaleString('it-IT');

  document.getElementById('modalMeta').innerHTML = `
    <div class="meta-chip">🌐 <span>${ev.ip}</span></div>
    <div class="meta-chip">📍 <span>${ev.city}, ${ev.country}</span></div>
    <div class="meta-chip">🔌 <span>${ev.service.toUpperCase()}</span></div>
    <div class="meta-chip">📅 <span>${ts}</span></div>
    <div class="meta-chip">⚠️ <span class="badge ${badgeClass}">${danger}</span></div>
  `;

  document.getElementById('modalContent').innerHTML = exp ? `
    <div class="ai-section">
      <div class="ai-label">🤖 ANALISI AI — COSA STA SUCCEDENDO</div>
      <div class="ai-text">${exp.explanation_it}</div>
    </div>
    <div class="advice-section">
      <div class="advice-label">💡 COME DIFENDERSI</div>
      <div class="advice-text">${exp.advice}</div>
    </div>` :
    '<div class="no-explanation" style="color:var(--muted);text-align:center;padding:20px;">Analisi AI non disponibile.</div>';

  document.getElementById('modalOverlay').classList.add('open');
}

function closeModal(e) {
  if (e.target === document.getElementById('modalOverlay')) closeModalDirect();
}

function closeModalDirect() {
  document.getElementById('modalOverlay').classList.remove('open');
}

document.addEventListener('keydown', e => { if (e.key === 'Escape') closeModalDirect(); });
</script>
</body>
